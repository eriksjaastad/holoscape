{
  "version": "3.0",
  "name": "Holoscape Classic",
  "author": "Holoscape team",
  "description": "Winamp 2.x-inspired chrome — flat dark grey with 1px beveled highlights, LCD-green accents on hover/active/selected. Subtle rounded-rectangle window shape (6px cut corners). Sprite sheets for the refresh button + tab backgrounds provide normal/hover/pressed/active state variants. Bordered + shadowed tab-bar container. First v3 skin designed to exercise every Amplify feature end-to-end; AmplifyDemo deliberately keeps flat demo colors.",
  "windowShape": {
    "kind": "polygons",
    "polygons": [
      { "points": [
        { "x": 6,    "y": 0   },
        { "x": 994,  "y": 0   },
        { "x": 1000, "y": 6   },
        { "x": 1000, "y": 694 },
        { "x": 994,  "y": 700 },
        { "x": 6,    "y": 700 },
        { "x": 0,    "y": 694 },
        { "x": 0,    "y": 6   }
      ] }
    ]
  },
  "surfaces": {
    "window.background": {
      "fill": { "kind": "color", "value": "#232323" }
    },
    "tabBar.container": {
      "fill": { "kind": "color", "value": "#2b2b2b" },
      "border": { "color": "#121212", "width": 1.0 },
      "corner": 2,
      "shadow": {
        "color":   "#000000",
        "opacity": 0.5,
        "blur":    6,
        "offsetX": 0,
        "offsetY": 2
      }
    },
    "tabBar.tab.normal": {
      "fill": {
        "kind": "image",
        "path": "assets/tab-sprite.png",
        "tile": "stretch",
        "sprite": {
          "cellWidth":  120,
          "cellHeight": 28,
          "rows": 1,
          "cols": 3,
          "stateMap": {
            "normal":  { "row": 0, "col": 0 },
            "hover":   { "row": 0, "col": 1 },
            "active":  { "row": 0, "col": 2 }
          }
        }
      }
    },
    "tabBar.tab.hover": {
      "fill": {
        "kind": "image",
        "path": "assets/tab-sprite.png",
        "tile": "stretch",
        "sprite": {
          "cellWidth":  120,
          "cellHeight": 28,
          "rows": 1,
          "cols": 3,
          "stateMap": {
            "normal":  { "row": 0, "col": 0 },
            "hover":   { "row": 0, "col": 1 },
            "active":  { "row": 0, "col": 2 }
          }
        }
      }
    },
    "tabBar.tab.active": {
      "fill": {
        "kind": "image",
        "path": "assets/tab-sprite.png",
        "tile": "stretch",
        "sprite": {
          "cellWidth":  120,
          "cellHeight": 28,
          "rows": 1,
          "cols": 3,
          "stateMap": {
            "normal":  { "row": 0, "col": 0 },
            "hover":   { "row": 0, "col": 1 },
            "active":  { "row": 0, "col": 2 }
          }
        }
      }
    },
    "sidebar.container": {
      "fill": { "kind": "color", "value": "#1c1c1c" },
      "border": { "color": "#121212", "width": 1.0 }
    },
    "sidebar.row.selected": {
      "fill": { "kind": "color", "value": "#00805a" }
    },
    "inputBox.container": {
      "fill": { "kind": "color", "value": "#1c1c1c" },
      "border": { "color": "#121212", "width": 1.0 }
    },
    "inputBox.field": {
      "fill": { "kind": "color", "value": "#141414" }
    },
    "sessionLauncher.container": {
      "fill": { "kind": "color", "value": "#2b2b2b" },
      "border": { "color": "#121212", "width": 1.0 }
    },
    "sessionLauncher.button.normal": {
      "fill": {
        "kind": "image",
        "path": "assets/button-sprite.png",
        "tile": "stretch",
        "sprite": {
          "cellWidth":  24,
          "cellHeight": 24,
          "rows": 1,
          "cols": 3,
          "stateMap": {
            "normal":  { "row": 0, "col": 0 },
            "hover":   { "row": 0, "col": 1 },
            "pressed": { "row": 0, "col": 2 }
          }
        }
      }
    },
    "sessionLauncher.button.hover": {
      "fill": {
        "kind": "image",
        "path": "assets/button-sprite.png",
        "tile": "stretch",
        "sprite": {
          "cellWidth":  24,
          "cellHeight": 24,
          "rows": 1,
          "cols": 3,
          "stateMap": {
            "normal":  { "row": 0, "col": 0 },
            "hover":   { "row": 0, "col": 1 },
            "pressed": { "row": 0, "col": 2 }
          }
        }
      }
    },
    "sessionLauncher.button.pressed": {
      "fill": {
        "kind": "image",
        "path": "assets/button-sprite.png",
        "tile": "stretch",
        "sprite": {
          "cellWidth":  24,
          "cellHeight": 24,
          "rows": 1,
          "cols": 3,
          "stateMap": {
            "normal":  { "row": 0, "col": 0 },
            "hover":   { "row": 0, "col": 1 },
            "pressed": { "row": 0, "col": 2 }
          }
        }
      }
    },
    "splitPane.divider": {
      "fill": { "kind": "color", "value": "#121212" }
    }
  }
}
