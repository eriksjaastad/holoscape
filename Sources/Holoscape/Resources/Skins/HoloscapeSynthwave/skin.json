{
  "version": "4.0",
  "name": "Holoscape Synthwave",
  "author": "Holoscape team",
  "description": "Retro synthwave dark — purple window gradient, teal-to-cyan tab bar, neon pink accents, ninepatch sidebar. v4 composed chrome with ambient particles + scanlines shader.",
  "chrome": {
    "mode": "composed",
    "width": 1000,
    "height": 700,
    "interiorRect": { "x": 0, "y": 32, "width": 1000, "height": 668 },
    "animations": [
      {
        "id": "ambient-sparks",
        "kind": "particle",
        "rect": { "x": 0, "y": 0, "width": 1000, "height": 700 },
        "z": 1,
        "phaseOffset": 0,
        "speedMultiplier": 1.0,
        "dataSource": "none",
        "params": {
          "particle": {
            "birthRate": 1.5,
            "lifetime": 6.0,
            "lifetimeRange": 1.5,
            "velocity": 8.0,
            "velocityRange": 4.0,
            "emissionAngle": 4.71,
            "emissionRange": 3.14,
            "color": "#ff4dd188",
            "scale": 0.3,
            "scaleRange": 0.1,
            "blendMode": "additive"
          }
        }
      },
      {
        "id": "scanlines-overlay",
        "kind": "shader",
        "rect": { "x": 0, "y": 0, "width": 1000, "height": 700 },
        "z": 2,
        "phaseOffset": 0,
        "speedMultiplier": 1.0,
        "params": {
          "shader": {
            "preset": "scanlines",
            "color": "#000000",
            "intensity": 0.08,
            "hz": 0.2
          }
        }
      }
    ]
  },
  "surfaces": {
    "window.background": {
      "fill": {
        "kind": "gradient",
        "direction": "vertical",
        "stops": [
          { "offset": 0.0, "color": "#1a0933" },
          { "offset": 1.0, "color": "#3d1a5e" }
        ]
      }
    },
    "tabBar.container": {
      "fill": {
        "kind": "gradient",
        "direction": "horizontal",
        "stops": [
          { "offset": 0.0, "color": "#0d4d6b" },
          { "offset": 1.0, "color": "#1a9fd4" }
        ]
      }
    },
    "tabBar.tab.active": {
      "fill": { "kind": "color", "value": "#ff4dd1" }
    },
    "tabBar.tab.idle": {
      "fill": { "kind": "color", "value": "#1a4d38" }
    },
    "tabBar.tab.permission": {
      "fill": { "kind": "color", "value": "#996633" }
    },
    "tabBar.tab.normal": {
      "fill": { "kind": "color", "value": "#1a2142" }
    },
    "sidebar.container": {
      "fill": {
        "kind": "image",
        "path": "assets/sidebar-tile.png",
        "tile": "ninepatch"
      }
    },
    "sidebar.row.selected": {
      "fill": { "kind": "color", "value": "#ff4dd1" }
    },
    "sidebar.row.indicator": {
      "fill": { "kind": "color", "value": "#1aff8c" },
      "states": [
        {
          "name": "connecting",
          "match": { "channelConnectionState": 1 },
          "fill": { "kind": "color", "value": "#ffcc00" }
        },
        {
          "name": "disconnected",
          "match": { "channelConnectionState": 2 },
          "fill": { "kind": "color", "value": "#ff3b30" }
        }
      ]
    },
    "inputBox.container": {
      "fill": { "kind": "color", "value": "#0f0820" }
    },
    "inputBox.field": {
      "fill": { "kind": "color", "value": "#1a0f33" }
    },
    "sessionLauncher.container": {
      "fill": { "kind": "color", "value": "#0d0820" }
    },
    "splitPane.divider": {
      "fill": { "kind": "color", "value": "#ff4dd1" }
    }
  }
}
